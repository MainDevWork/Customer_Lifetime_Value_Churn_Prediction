# Virtual environment
.venv/

# DuckDB database -- generated by running sql/01_schema.sql and sql/02_load.sql
telco.duckdb
*.duckdb
*.duckdb.wal

# Python
__pycache__/
*.py[cod]

# Jupyter
.ipynb_checkpoints/

# Local data files -- source data is downloaded via kagglehub, not stored in the repo
data/*
*.xlsx
*.csv

# The one exception: the reporting export, generated by sql/07_export.sql. It is
# committed because telco.duckdb is not, so without it the Power BI report has
# no data source and cannot be opened from a fresh clone.
!data/customer_export.csv

# OS / editor
.DS_Store
Thumbs.db
.vscode/
