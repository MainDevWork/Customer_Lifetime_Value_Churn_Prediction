# Virtual environment
.venv/

# DuckDB database -- generated by running sql/01_schema.sql and sql/02_load.sql
telco.duckdb
*.duckdb
*.duckdb.wal

# Python
__pycache__/
*.py[cod]

# Jupyter
.ipynb_checkpoints/

# Local data files -- source data is downloaded via kagglehub, not stored in the repo
data/*
*.xlsx
*.csv

# The two exceptions: the reporting exports, generated by sql/07_export.sql and
# sql/06_sensitivity.sql. They are committed because telco.duckdb is not, so
# without them the Power BI report has no data source and cannot be opened from
# a fresh clone.
!data/customer_export.csv
!data/sensitivity_export.csv

# Power BI. The project is stored in the text-based .pbip format so the report
# definition can be reviewed in a diff like any other source file. Local caches
# and user settings that Power BI Desktop writes alongside it are not source.
powerbi/**/.pbi/
powerbi/**/cache.abf
powerbi/**/*.pbix

# OS / editor
.DS_Store
Thumbs.db
.vscode/
