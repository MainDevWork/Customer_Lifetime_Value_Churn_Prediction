model Model
	culture: en-GB
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-GB
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Customers","Sensitivity"]

annotation PBI_ProTooling = ["DevMode"]

ref table Customers
ref table Sensitivity
ref expression RepoPath
