	partition Sensitivity = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(RepoPath & "\data\sensitivity_export.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				    Typed = Table.TransformColumnTypes(Headers, {{"success_rate", type number}, {"customers_contacted", Int64.Type}, {"pct_of_base", type number}, {"net_return_targeted", type number}, {"net_return_contact_everyone", type number}, {"total_cost", type number}, {"return_on_spend_pct", type number}})
				in
				    Typed

	annotation PBI_ResultType = Table
