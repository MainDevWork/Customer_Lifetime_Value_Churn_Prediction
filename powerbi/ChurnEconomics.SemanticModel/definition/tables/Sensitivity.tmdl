table Sensitivity
	lineageTag: 9c1f0a11-0005-4a00-9000-000000000001

	measure 'Sens Net Targeted' = ```
			SUM('Sensitivity'[net_return_targeted])
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000100
		displayFolder: 4 Sensitivity

	measure 'Sens Net Everyone' = ```
			SUM('Sensitivity'[net_return_contact_everyone])
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000101
		displayFolder: 4 Sensitivity

	measure 'Sens Customers Contacted' = ```
			SUM('Sensitivity'[customers_contacted])
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000102
		displayFolder: 4 Sensitivity

	measure 'Sens Return on Spend' = ```
			SUM('Sensitivity'[return_on_spend_pct]) / 100
			```
		formatString: "0.0%"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000103
		displayFolder: 4 Sensitivity

