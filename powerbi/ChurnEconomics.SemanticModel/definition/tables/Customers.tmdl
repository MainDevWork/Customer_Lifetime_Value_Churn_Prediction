	partition Customers = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(RepoPath & "\data\customer_export.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				    Typed = Table.TransformColumnTypes(Headers, {{"customer_id", type text}, {"clv", type number}, {"value_decile", Int64.Type}, {"churn_probability", type number}, {"decision", type text}, {"net_value", type number}, {"value_at_risk", type number}, {"expected_value_saved", type number}, {"intervention_cost", type number}, {"churn_value", Int64.Type}, {"data_split", type text}, {"predicted_churn", Int64.Type}, {"outcome_class", type text}, {"churn_reason", type text}, {"contract", type text}, {"tenure_band", type text}, {"spend_band", type text}, {"city", type text}, {"latitude", type number}, {"longitude", type number}})
				in
				    Typed

	annotation PBI_ResultType = Table
