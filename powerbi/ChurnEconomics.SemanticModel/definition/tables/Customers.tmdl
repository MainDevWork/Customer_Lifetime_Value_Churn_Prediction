table Customers
	lineageTag: 9c1f0a11-0004-4a00-9000-000000000001

	measure 'Customers' = ```
			COUNTROWS('Customers')
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000001
		displayFolder: 1 Scale

	measure 'Book Value' = ```
			SUM('Customers'[clv])
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000002
		displayFolder: 1 Scale

	measure 'Value at Risk' = ```
			SUM('Customers'[value_at_risk])
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000003
		displayFolder: 1 Scale

	measure 'Targeted Customers' = ```
			CALCULATE([Customers], 'Customers'[decision] = "Intervene")
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000004
		displayFolder: 2 Decision

	measure 'Customers Left Alone' = ```
			CALCULATE([Customers], 'Customers'[decision] = "Do not intervene")
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000005
		displayFolder: 2 Decision

	measure 'Share Targeted' = ```
			DIVIDE([Targeted Customers], [Customers])
			```
		formatString: "0.0%"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000006
		displayFolder: 2 Decision

	measure 'Net if Targeted' = ```
			CALCULATE(SUM('Customers'[net_value]), 'Customers'[decision] = "Intervene")
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000007
		displayFolder: 2 Decision

	measure 'Net if Contact Everyone' = ```
			SUM('Customers'[net_value])
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000008
		displayFolder: 2 Decision

	measure 'Value Destroyed by Untargeted Contact' = ```
			CALCULATE(SUM('Customers'[net_value]), 'Customers'[decision] = "Do not intervene")
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000009
		displayFolder: 2 Decision

	measure 'Decision Swing' = ```
			[Net if Targeted] - [Net if Contact Everyone]
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000010
		displayFolder: 2 Decision

	measure 'Value Recovered' = ```
			CALCULATE(SUM('Customers'[expected_value_saved]), 'Customers'[decision] = "Intervene")
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000011
		displayFolder: 2 Decision

	measure 'Contact Cost' = ```
			CALCULATE(SUM('Customers'[intervention_cost]), 'Customers'[decision] = "Intervene")
			```
		formatString: "\R#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000012
		displayFolder: 2 Decision

	measure 'Return on Spend' = ```
			DIVIDE([Net if Targeted], [Contact Cost])
			```
		formatString: "0.0%"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000013
		displayFolder: 2 Decision

	measure 'Test Customers' = ```
			CALCULATE([Customers], 'Customers'[data_split] = "test")
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000014
		displayFolder: 3 Model

	measure 'Actual Leavers' = ```
			CALCULATE([Customers], 'Customers'[data_split] = "test", 'Customers'[churn_value] = 1)
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000015
		displayFolder: 3 Model

	measure 'Caught' = ```
			CALCULATE([Customers], 'Customers'[data_split] = "test", 'Customers'[outcome_class] = "Caught")
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000016
		displayFolder: 3 Model

	measure 'Missed' = ```
			CALCULATE([Customers], 'Customers'[data_split] = "test", 'Customers'[outcome_class] = "Missed")
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000017
		displayFolder: 3 Model

	measure 'False Alarms' = ```
			CALCULATE([Customers], 'Customers'[data_split] = "test", 'Customers'[outcome_class] = "False alarm")
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000018
		displayFolder: 3 Model

	measure 'Correctly Left Alone' = ```
			CALCULATE([Customers], 'Customers'[data_split] = "test", 'Customers'[outcome_class] = "Correctly left alone")
			```
		formatString: "#,0"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000019
		displayFolder: 3 Model

	measure 'Recall' = ```
			DIVIDE([Caught], [Caught] + [Missed])
			```
		formatString: "0.0%"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000020
		displayFolder: 3 Model

	measure 'Precision' = ```
			DIVIDE([Caught], [Caught] + [False Alarms])
			```
		formatString: "0.0%"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000021
		displayFolder: 3 Model

	measure 'Accuracy' = ```
			DIVIDE([Caught] + [Correctly Left Alone], [Test Customers])
			```
		formatString: "0.0%"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000022
		displayFolder: 3 Model

	measure 'Baseline Accuracy' = ```
			DIVIDE([Test Customers] - [Actual Leavers], [Test Customers])
			```
		formatString: "0.0%"
		lineageTag: 9c1f0a11-0003-4a00-9000-000000000023
		displayFolder: 3 Model

