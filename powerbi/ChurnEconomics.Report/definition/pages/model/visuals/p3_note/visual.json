                ]
              },
              {
                "horizontalTextAlignment": "left",
                "textRuns": [
                  {
                    "value": "ROC AUC is 0.838, inside the usual range for this dataset. A figure near 1.0 would suggest the inputs gave the answer away.",
                    "textStyle": {
                      "fontSize": "10pt",
                      "color": "#898781",
                      "fontFamily": "Segoe UI"
                    }
                  }
                ]
              },
              {
                "horizontalTextAlignment": "left",
                "textRuns": [
                  {
                    "value": "",
                    "textStyle": {
                      "fontSize": "10pt",
                      "color": "#898781",
                      "fontFamily": "Segoe UI"
                    }
                  }
                ]
              },
              {
                "horizontalTextAlignment": "left",
                "textRuns": [
                  {
                    "value": "Overall accuracy of 73.9% sits just above the 73.5% available from predicting that nobody ever leaves. Judged on accuracy alone the model looks worthless; it in fact finds close to four in five leavers. This is why precision and recall are reported instead.",
                    "textStyle": {
                      "fontSize": "10pt",
                      "color": "#898781",
                      "fontFamily": "Segoe UI"
                    }
                  }
                ]
              },
              {
                "horizontalTextAlignment": "left",
                "textRuns": [
                  {
                    "value": "",
                    "textStyle": {
                      "fontSize": "10pt",
                      "color": "#898781",
                      "fontFamily": "Segoe UI"
                    }
                  }
                ]
              },
              {
                "horizontalTextAlignment": "left",
                "textRuns": [
                  {
                    "value": "Roughly one flag in two is a customer who was not leaving. That is not a fault to be fixed \u2014 it is the limit of predicting departure from a customer profile, and it is priced into the economics rather than argued around.",
                    "textStyle": {
                      "fontSize": "10pt",
                      "color": "#898781",
                      "fontFamily": "Segoe UI"
                    }
                  }
                ]
              }
            ]
          }
